{
  "name": "hane",
  "main": "expo-router/entry",
  "version": "1.0.11",
  "scripts": {
    "start": "bash scripts/dev.sh",
    "dev:sim": "bash scripts/dev-sim.sh",
    "deploy": "bash scripts/deploy.sh",
    "deploy:ota": "eas update --channel production --platform ios --environment production",
    "deploy:build": "eas build --platform ios --profile production",
    "reset-project": "node ./scripts/reset-project.js",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "lint": "expo lint",
    "typecheck:functions": "cd supabase/functions/api && deno check **/*.ts",
    "lint:functions": "cd supabase/functions/api && deno lint",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "format:functions": "deno fmt supabase/functions",
    "db:up": "bash scripts/db-up.sh",
    "db:down": "bash scripts/db-down.sh",
    "db:reset": "bash scripts/db-reset.sh",
    "db:fixtures": "bash scripts/db-fixtures.sh",
    "db:types": "supabase gen types typescript --local > types/database.ts",
    "db:drizzle": "drizzle-kit introspect --config drizzle.config.ts",
    "api:serve": "supabase functions serve api --env-file .env.local --no-verify-jwt",
    "api:spec": "deno run -A supabase/functions/api/scripts/emit-spec.ts > openapi.json",
    "api:gen": "orval --config orval.config.ts",
    "codegen": "npm run db:types && npm run db:drizzle && npm run api:spec && npm run api:gen",
    "prebuild:local": "bash scripts/check-local-build-deps.sh",
    "build:local": "EAS_BUILD_NO_EXPO_GO_WARNING=true eas build --platform ios --profile production --local --output builds/app.ipa",
    "build:device": "expo run:ios --device",
    "submit:local": "eas submit --platform ios --profile production --path builds/app.ipa",
    "seed:prod": "npx tsx --env-file .env.local scripts/seed-prod.ts",
    "prepare": "husky"
  },
  "dependencies": {
    "@expo-google-fonts/dm-serif-display": "^0.4.2",
    "@expo-google-fonts/geist": "^0.4.1",
    "@expo/vector-icons": "^15.0.3",
    "@hookform/resolvers": "^5.2.2",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/datetimepicker": "8.4.4",
    "@react-navigation/bottom-tabs": "^7.15.5",
    "@react-navigation/elements": "^2.9.10",
    "@react-navigation/native": "^7.1.33",
    "@supabase/supabase-js": "^2.99.0",
    "@tailwindcss/postcss": "^4.2.1",
    "@tanstack/react-query": "^5.90.21",
    "clsx": "^2.1.1",
    "expo": "~54.0.33",
    "expo-apple-authentication": "~8.0.8",
    "expo-blur": "~15.0.8",
    "expo-constants": "~18.0.13",
    "expo-dev-client": "~6.0.20",
    "expo-device": "~8.0.10",
    "expo-font": "~14.0.11",
    "expo-haptics": "~15.0.8",
    "expo-image": "~3.0.11",
    "expo-image-manipulator": "~14.0.8",
    "expo-image-picker": "~17.0.10",
    "expo-linear-gradient": "~15.0.8",
    "expo-linking": "~8.0.11",
    "expo-notifications": "~0.32.16",
    "expo-router": "~6.0.23",
    "expo-sms": "~14.0.8",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "expo-symbols": "~1.0.8",
    "expo-system-ui": "~6.0.9",
    "expo-updates": "~29.0.16",
    "expo-web-browser": "~15.0.10",
    "libphonenumber-js": "^1.12.39",
    "nativewind": "^5.0.0-preview.2",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-hook-form": "^7.71.2",
    "react-native": "0.81.5",
    "react-native-css": "^3.0.4",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-url-polyfill": "^3.0.0",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.5.1",
    "sonner-native": "^0.23.1",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/jsonwebtoken": "^9.0.10",
    "@types/react": "~19.1.0",
    "drizzle-kit": "^0.31.10",
    "drizzle-orm": "^0.45.2",
    "eslint": "^9.25.0",
    "eslint-config-expo": "~10.0.0",
    "husky": "^9.1.7",
    "jsonwebtoken": "^9.0.3",
    "lint-staged": "^16.3.3",
    "orval": "^8.8.0",
    "postgres": "^3.4.9",
    "prettier": "^3.8.1",
    "supabase": "2.75.0",
    "typescript": "~5.9.2"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix --no-warn-ignored",
      "prettier --write"
    ],
    "*.{js,json,md,css}": "prettier --write"
  },
  "private": true,
  "overrides": {
    "lightningcss": "1.30.1"
  }
}
