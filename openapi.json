{
  "openapi": "3.0.0",
  "info": {
    "title": "Wyng API",
    "version": "1.0.0"
  },
  "components": {
    "securitySchemes": {
      "Bearer": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    },
    "schemas": {
      "DiscoverProfile": {
        "type": "object",
        "properties": {
          "profileId": {
            "type": "string",
            "format": "uuid"
          },
          "userId": {
            "type": "string",
            "format": "uuid"
          },
          "chosenName": {
            "type": "string"
          },
          "gender": {
            "type": "string",
            "nullable": true,
            "enum": ["Male", "Female", "Non-Binary"]
          },
          "age": {
            "type": "integer"
          },
          "city": {
            "type": "string",
            "enum": ["Boston", "New York"]
          },
          "bio": {
            "type": "string",
            "nullable": true
          },
          "datingStatus": {
            "type": "string",
            "enum": ["open", "break", "winging"]
          },
          "interests": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": [
                "Travel",
                "Fitness",
                "Cooking",
                "Music",
                "Art",
                "Movies",
                "Books",
                "Gaming",
                "Outdoors",
                "Sports",
                "Technology",
                "Fashion",
                "Food",
                "Photography",
                "Dance",
                "Volunteering"
              ]
            }
          },
          "firstPhoto": {
            "type": "string",
            "nullable": true
          },
          "wingNote": {
            "type": "string",
            "nullable": true
          },
          "suggestedBy": {
            "type": "string",
            "nullable": true,
            "format": "uuid"
          },
          "suggesterName": {
            "type": "string",
            "nullable": true
          }
        },
        "required": [
          "profileId",
          "userId",
          "chosenName",
          "gender",
          "age",
          "city",
          "bio",
          "datingStatus",
          "interests",
          "firstPhoto",
          "wingNote",
          "suggestedBy",
          "suggesterName"
        ]
      },
      "DiscoverResponse": {
        "type": "array",
        "items": {
          "$ref": "#/components/schemas/DiscoverProfile"
        }
      },
      "LikesYouProfile": {
        "type": "object",
        "properties": {
          "profileId": {
            "type": "string",
            "format": "uuid"
          },
          "userId": {
            "type": "string",
            "format": "uuid"
          },
          "chosenName": {
            "type": "string"
          },
          "gender": {
            "type": "string",
            "nullable": true,
            "enum": ["Male", "Female", "Non-Binary"]
          },
          "age": {
            "type": "integer"
          },
          "city": {
            "type": "string",
            "enum": ["Boston", "New York"]
          },
          "bio": {
            "type": "string",
            "nullable": true
          },
          "datingStatus": {
            "type": "string",
            "enum": ["open", "break", "winging"]
          },
          "interests": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": [
                "Travel",
                "Fitness",
                "Cooking",
                "Music",
                "Art",
                "Movies",
                "Books",
                "Gaming",
                "Outdoors",
                "Sports",
                "Technology",
                "Fashion",
                "Food",
                "Photography",
                "Dance",
                "Volunteering"
              ]
            }
          },
          "firstPhoto": {
            "type": "string",
            "nullable": true
          },
          "wingNote": {
            "type": "string",
            "nullable": true
          },
          "suggestedBy": {
            "type": "string",
            "nullable": true,
            "format": "uuid"
          },
          "suggesterName": {
            "type": "string",
            "nullable": true
          }
        },
        "required": [
          "profileId",
          "userId",
          "chosenName",
          "gender",
          "age",
          "city",
          "bio",
          "datingStatus",
          "interests",
          "firstPhoto",
          "wingNote",
          "suggestedBy",
          "suggesterName"
        ]
      },
      "LikesYouResponse": {
        "type": "array",
        "items": {
          "$ref": "#/components/schemas/LikesYouProfile"
        }
      },
      "LikesYouCountResponse": {
        "type": "object",
        "properties": {
          "count": {
            "type": "integer",
            "minimum": 0
          }
        },
        "required": ["count"]
      },
      "WingerTab": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "name": {
            "type": "string"
          }
        },
        "required": ["id", "name"]
      },
      "WingerTabsResponse": {
        "type": "array",
        "items": {
          "$ref": "#/components/schemas/WingerTab"
        }
      }
    },
    "parameters": {}
  },
  "paths": {
    "/api/discover": {
      "get": {
        "tags": ["discover"],
        "security": [
          {
            "Bearer": []
          }
        ],
        "parameters": [
          {
            "schema": {
              "type": "string",
              "format": "uuid"
            },
            "required": false,
            "name": "filterWingerId",
            "in": "query"
          },
          {
            "schema": {
              "type": "integer",
              "minimum": 1,
              "maximum": 100,
              "default": 20
            },
            "required": false,
            "name": "pageSize",
            "in": "query"
          },
          {
            "schema": {
              "type": "integer",
              "nullable": true,
              "minimum": 0,
              "default": 0
            },
            "required": false,
            "name": "pageOffset",
            "in": "query"
          },
          {
            "schema": {
              "type": "boolean",
              "nullable": true,
              "default": false
            },
            "required": false,
            "name": "wingerOnly",
            "in": "query"
          }
        ],
        "responses": {
          "200": {
            "description": "Discover pool for the viewer",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DiscoverResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthenticated"
          }
        }
      }
    },
    "/api/likes-you": {
      "get": {
        "tags": ["likes-you"],
        "security": [
          {
            "Bearer": []
          }
        ],
        "parameters": [
          {
            "schema": {
              "type": "integer",
              "minimum": 1,
              "maximum": 100,
              "default": 20
            },
            "required": false,
            "name": "pageSize",
            "in": "query"
          },
          {
            "schema": {
              "type": "integer",
              "nullable": true,
              "minimum": 0,
              "default": 0
            },
            "required": false,
            "name": "pageOffset",
            "in": "query"
          }
        ],
        "responses": {
          "200": {
            "description": "Profiles who have liked the viewer and remain available",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/LikesYouResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthenticated"
          }
        }
      }
    },
    "/api/likes-you/count": {
      "get": {
        "tags": ["likes-you"],
        "security": [
          {
            "Bearer": []
          }
        ],
        "responses": {
          "200": {
            "description": "Count of pending inbound likes for the viewer",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/LikesYouCountResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthenticated"
          }
        }
      }
    },
    "/api/winger-tabs": {
      "get": {
        "tags": ["winger-tabs"],
        "security": [
          {
            "Bearer": []
          }
        ],
        "responses": {
          "200": {
            "description": "Distinct wingers with pending suggestions for the viewer, most recent first",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/WingerTabsResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthenticated"
          }
        }
      }
    }
  }
}
